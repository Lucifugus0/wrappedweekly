# Dipakai oleh docker-compose.yml di root

# Database (dibagi ke postgres, migrate, dan backend service)
DB_USER=wrapped
DB_PASSWORD=wrapped
DB_NAME=wrapped_weekly

# Frontend build-time — URL API yang dipanggil dari browser.
# Di belakang Nginx (docker-compose), browser & Nginx satu origin, jadi cukup path relatif.
NEXT_PUBLIC_API_URL=/api/v1

# Dipakai backend untuk CORS — origin frontend yang boleh mengakses API.
# Saat akses lewat Nginx di http://localhost, origin browser adalah ini.
FRONTEND_BASE_URL=http://localhost
