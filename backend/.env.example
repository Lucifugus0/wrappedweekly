# Server
PORT=8080
APP_ENV=development

# Database (format: postgres://user:password@host:5432/dbname?sslmode=disable)
DATABASE_URL=postgres://wrapped:wrapped@localhost:5432/wrapped_weekly?sslmode=disable

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRY_HOURS=24

# Cookie (auth token disimpan sebagai httpOnly cookie)
COOKIE_SECURE=false
COOKIE_DOMAIN=
# Set "true" HANYA jika frontend & backend di-deploy di domain berbeda
# (mis. frontend di Vercel, backend di Render/Railway/Fly.io) — wajib HTTPS.
# Biarkan "false" untuk setup lokal/Docker di belakang Nginx (same-origin).
COOKIE_CROSS_SITE=false

# AI narrative provider: "mock" (default, deterministik, tanpa API key) atau provider asli
AI_PROVIDER=mock

# Dipakai untuk CORS — origin frontend yang boleh akses API
FRONTEND_BASE_URL=http://localhost:3000
